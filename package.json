{
  "name": "microservices-monorepo",
  "private": true,
  "workspaces": [
    "services/*",
    "shared"
  ],
  "scripts": {
    "infra:up": "docker-compose up -d",
    "infra:down": "docker-compose down",

    "auth:dev": "npm run start:dev --workspace=auth",
    "auth:build": "npm run build --workspace=auth",
    "auth:test": "npm run test --workspace=auth",
    
    "book:dev": "npm run start:dev --workspace=book",
    "book:build": "npm run build --workspace=book",
    "book:test": "npm run test --workspace=book",
    "notification:dev": "npm run start:dev --workspace=notification",
    "notification:build": "npm run build --workspace=notification",
    "notification:test": "npm run test --workspace=notification",
    "order:dev": "npm run start:dev --workspace=order",
    "order:build": "npm run build --workspace=order",
    "order:test": "npm run test --workspace=order",
    "review:dev": "npm run start:dev --workspace=review",
    "review:build": "npm run build --workspace=review",
    "review:test": "npm run test --workspace=review",
    "dev:all": "npm run auth:dev & npm run book:dev & npm run notification:dev & npm run order:dev & npm run review:dev",
    "build:all": "npm run build --workspaces --if-present"
  },
  "dependencies": {
    "@sentry/nestjs": "^10.66.0",
    "@sentry/profiling-node": "^10.66.0"
  }
}
